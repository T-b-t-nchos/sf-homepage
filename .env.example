# Discord Webhook URL for notifications (server-side only)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Discord OAuth2
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:5173/api/auth/callback
APP_BASE_URL=http://localhost:5173
SESSION_SECRET=change_me_to_a_long_random_string

# Optional: comma-separated Discord user IDs allowed to cancel presenters.
# Example: LT1_CANCEL_ADMIN_IDS=123456789012345678,987654321098765432
LT1_CANCEL_ADMIN_IDS=957974197953511524,ANOTHER_ID_HERE
# Backward-compatible alias used in older branches.
ADMIN_DISCORD_IDS=957974197953511524,ANOTHER_ID_HERE
LT1_PRESENTER_CANCEL_ENABLED=false

# Optional: trusted proxy settings for IP-based rate limiting.
# Set TRUST_PROXY=true only when requests always come through the selected provider.
TRUST_PROXY=false
# Supported values: vercel, cloudflare
TRUSTED_PROXY_PROVIDER=

# Optional but strongly recommended for production vote integrity (Upstash/Vercel KV REST)
KV_REST_API_URL=
KV_REST_API_TOKEN=
LT1_VOTE_ENABLED=false

# Optional emergency kill-switch for submissions.
LT1_SUBMIT_ENABLED=true

# YouTube PR Video URL (embed format: https://www.youtube.com/embed/VIDEO_ID)
VITE_YOUTUBE_PR_VIDEO_URL=

# Frontend feature flag for vote page exposure.
VITE_LT1_VOTE_ENABLED=false
